# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxx
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_ID=proj_xxx

# Encryption (AES-256-GCM for credential storage)
ENCRYPTION_KEY=64-char-hex-string

# Notifications
RESEND_API_KEY=re_xxx
NOTIFICATION_EMAIL=admin@example.com

# Proxy providers (optional)
WEBSHARE_API_KEY=xxx
BRIGHTDATA_PROXY_URL=http://user:pass@host:port

# Firecrawl (optional proxy for fetch)
FIRECRAWL_API_KEY=fc_xxx

# Clerk (JWT verification for frontend auth)
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Server
NODE_ENV=development
PORT=3000

# Skip getCurrentAppointment() to save request budget (1 fewer request per poll)
SKIP_APPOINTMENT_SYNC=true

# RPi deployment (optional)
RPI_HOST=192.168.x.x
RPI_USER=pi
RPI_PASS=xxx
RPI_PATH=/home/pi/visa-scraper

# Webhook (optional)
WEBHOOK_URL=https://your-webhook.example.com/hook
WEBHOOK_SECRET=hmac-secret

# Testing (optional, personal IDs)
TEST_USER_ID=
TEST_SCHEDULE_ID=
TEST_APPLICANT_IDS=

# Dashboard auth
DASHBOARD_PASSWORD=your-dashboard-password
COOKIE_SECRET=your-random-cookie-secret
